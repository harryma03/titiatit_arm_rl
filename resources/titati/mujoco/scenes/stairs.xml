<mujoco model="titatit_stairs">
  <include file="../wheeled_titatit_rl.xml"/>

  <statistic center="2 0 0.4" extent="4"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.35 0.35 0.35" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.35 0.5 0.7" rgb2="0.02 0.03 0.04" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.25 0.28 0.28" rgb2="0.12 0.15 0.16" markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.15"/>
    <material name="step_mat" rgba="0.6 0.4 0.2 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 2.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane" friction="1.0 0.01 0.01"/>

    <!-- ===== 上台阶 (沿 X 正方向) ===== -->
    <!-- 台阶参数: 每级宽0.3m, 高0.08m, 深0.3m -->
    <geom name="step_01" pos="1.5 0.0 0.04" type="box" size="0.15 0.6 0.04" material="step_mat"/>
    <geom name="step_02" pos="1.8 0.0 0.12" type="box" size="0.15 0.6 0.04" material="step_mat"/>
    <geom name="step_03" pos="2.1 0.0 0.20" type="box" size="0.15 0.6 0.04" material="step_mat"/>
    <geom name="step_04" pos="2.4 0.0 0.28" type="box" size="0.15 0.6 0.04" material="step_mat"/>
    <geom name="step_05" pos="2.7 0.0 0.36" type="box" size="0.15 0.6 0.04" material="step_mat"/>
    <geom name="step_06" pos="3.0 0.0 0.44" type="box" size="0.15 0.6 0.04" material="step_mat"/>
    <geom name="step_07" pos="3.3 0.0 0.52" type="box" size="0.15 0.6 0.04" material="step_mat"/>
    <geom name="step_08" pos="3.6 0.0 0.60" type="box" size="0.15 0.6 0.04" material="step_mat"/>

    <!-- 平台 -->
    <geom name="platform" pos="4.2 0.0 0.60" type="box" size="0.45 0.6 0.04" material="step_mat"/>

    <!-- ===== 下台阶 ===== -->
    <geom name="step_09" pos="4.8 0.0 0.52" type="box" size="0.15 0.6 0.04" material="step_mat"/>
    <geom name="step_10" pos="5.1 0.0 0.44" type="box" size="0.15 0.6 0.04" material="step_mat"/>
    <geom name="step_11" pos="5.4 0.0 0.36" type="box" size="0.15 0.6 0.04" material="step_mat"/>
    <geom name="step_12" pos="5.7 0.0 0.28" type="box" size="0.15 0.6 0.04" material="step_mat"/>
    <geom name="step_13" pos="6.0 0.0 0.20" type="box" size="0.15 0.6 0.04" material="step_mat"/>
    <geom name="step_14" pos="6.3 0.0 0.12" type="box" size="0.15 0.6 0.04" material="step_mat"/>
    <geom name="step_15" pos="6.6 0.0 0.04" type="box" size="0.15 0.6 0.04" material="step_mat"/>
  </worldbody>
</mujoco>
